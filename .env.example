# FocusTrack — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env real.

# ── Servidor ──────────────────────────────────────────────────
PORT=3001

# ── SharePoint / Microsoft Graph ──────────────────────────────
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=
SHAREPOINT_SITE_URL=https://seudominio.sharepoint.com/sites/SeuSite
SHAREPOINT_TICKETS_LIST_ID=
SHAREPOINT_TIME_ENTRIES_LIST_ID=

# Mapeamento e-mail → LookupId do SharePoint
# Formato JSON: {"email@dominio.com":10}
SHAREPOINT_USER_LOOKUP_MAP=

FOCUSTRACK_DEFAULT_USER_EMAIL=
FOCUSTRACK_DEFAULT_USER_LOOKUP_ID=

# ── Campos SharePoint (opcional — sobrescreve padrão) ─────────
SP_FIELD_TICKET_REQUESTER_LOOKUP=SolicitanteLookupId
SP_FIELD_TIME_RESPONSIBLE_LOOKUP=Respons_x00e1_velLookupId
SP_FIELD_TICKET_CREATED_AT=DataCria_x00e7__x00e3_o
SP_FIELD_TICKET_STATUS=Status
SP_FIELD_TICKET_STARTED_AT=InicioPlanejado
SP_FIELD_TICKET_FINISHED_AT=DataConclus_x00e3_o
SP_FIELD_TICKET_TIME_SPENT=TempoGasto
SP_VALUE_TICKET_STATUS_IN_PROGRESS=Em andamento
SP_VALUE_TICKET_STATUS_FINISHED=Concluído
SP_FIELD_TIME_CENTRAL_COMMENT=ComentarioCentralDemandas
SP_FIELD_TIME_SEND_CENTRAL_COMMENT=EnviarComentarioCentral
SP_FIELD_TIME_CENTRAL_COMMENT_SENT=ComentarioCentralEnviado
SP_FIELD_TIME_CENTRAL_COMMENT_ERROR=ErroComentarioCentral
SP_NATIVE_COMMENTS_ENABLED=false

# ── AI narrative ──────────────────────────────────────────────
# Compatível com qualquer API no estilo OpenAI (Monica, OpenAI, Azure OpenAI, etc.)
AI_API_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_API_RESPONSE_FORMAT=json_object

# OpenAI (alias — usado como fallback se AI_API_KEY não estiver definido)
OPENAI_API_KEY=
OPENAI_MODEL=

# ── Relatório semanal ─────────────────────────────────────────
# URL base do backend Express (para o script de envio)
WEEKLY_REPORT_BASE_URL=http://localhost:3001

WEEKLY_REPORT_FROM=FocusTrack <seuemail@empresa.com.br>
WEEKLY_REPORT_TO=destinatario@empresa.com.br
WEEKLY_REPORT_CC=
WEEKLY_REPORT_BCC=
WEEKLY_REPORT_TIMEZONE=America/Cuiaba

# ── SMTP ──────────────────────────────────────────────────────
# Exemplo Office 365:
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seuemail@empresa.com.br
SMTP_PASS=
